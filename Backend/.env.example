# --- AWS CONFIGURATION ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- MYSQL DATABASE CONFIGURATION ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=pasmi

# Connection pool configuration (tune based on workload)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- JWT AUTHENTICATION ---
# IMPORTANT: Generate a strong random secret for production
# Example: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# --- OAUTH / AI INTEGRATION ---
NEON_AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
OPENAI_API_KEY=

# --- GOOGLE CLOUD CONFIGURATION (for Imagen 3 thumbnail generation) ---
# Service Account JSON file for Speech-to-Text (path to file)
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# API Key for Imagen 3 (image generation only)
GOOGLE_CLOUD_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=

# --- APPLICATION CONFIGURATION ---
APP_ENV=development
LOG_LEVEL=INFO

